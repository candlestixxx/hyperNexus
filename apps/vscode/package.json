{
  "name": "hypercode-vscode-extension",
  "displayName": "Hypercode Plugin",
  "version": "1.0.0-alpha.62",
  "description": "Connect VS Code to Hypercode Hub for AI agent orchestration, memory management, and tool invocation",
  "publisher": "hypercode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "agents",
    "mcp",
    "orchestration",
    "memory"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "hypercode.connect",
        "title": "Hypercode: Connect to Core"
      },
      {
        "command": "hypercode.disconnect",
        "title": "Hypercode: Disconnect from Core"
      },
      {
        "command": "hypercode.showStatus",
        "title": "Hypercode: Show Hub Status"
      },
      {
        "command": "hypercode.runAgent",
        "title": "Hypercode: Run Agent"
      },
      {
        "command": "hypercode.searchMemory",
        "title": "Hypercode: Search Memory"
      },
      {
        "command": "hypercode.ingestUrl",
        "title": "Hypercode: Ingest URL to Knowledge"
      },
      {
        "command": "hypercode.ingestSelectionToRag",
        "title": "Hypercode: Ingest Selection to RAG"
      },
      {
        "command": "hypercode.rememberSelection",
        "title": "Hypercode: Remember Selection"
      },
      {
        "command": "hypercode.listTools",
        "title": "Hypercode: List Tools"
      },
      {
        "command": "hypercode.invokeTool",
        "title": "Hypercode: Invoke Tool"
      },
      {
        "command": "hypercode.openDashboard",
        "title": "Hypercode: Open Dashboard"
      },
      {
        "command": "hypercode.showLogs",
        "title": "Hypercode: Show Logs"
      },
      {
        "command": "hypercode.startDebate",
        "title": "Hypercode: Start Council Debate"
      },
      {
        "command": "hypercode.viewAnalytics",
        "title": "Hypercode: View Supervisor Analytics"
      },
      {
        "command": "hypercode.listDebateTemplates",
        "title": "Hypercode: List Debate Templates"
      },
      {
        "command": "hypercode.architectMode",
        "title": "Hypercode: Architect Mode (Two-Model)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hypercodeSidebar",
          "title": "Hypercode",
          "icon": "resources/hypercode.svg"
        }
      ]
    },
    "views": {
      "hypercodeSidebar": [
        {
          "type": "webview",
          "id": "hypercode.dispatchView",
          "name": "Mini Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "Hypercode",
      "properties": {
        "hypercode.coreUrl": {
          "type": "string",
          "default": "ws://localhost:3001",
          "description": "URL of the Hypercode Core WebSocket server"
        },
        "hypercode.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authenticated Core access"
        },
        "hypercode.dashboardUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the Hypercode web dashboard used for deep links from the VS Code extension"
        },
        "hypercode.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to Core on startup"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "hypercode.ingestSelectionToRag",
          "when": "editorHasSelection",
          "group": "hypercode@1"
        },
        {
          "command": "hypercode.rememberSelection",
          "when": "editorHasSelection",
          "group": "hypercode@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint --no-eslintrc --parser @typescript-eslint/parser \"src/**/*.{ts,tsx,js,mjs,cjs}\"",
    "build": "tsup src/extension.ts --format cjs --external vscode",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^9.26.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
