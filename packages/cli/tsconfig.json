{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": false,
    "declarationMap": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "paths": {
      "@hypernexus/core": [
        "../core/src/index.ts"
      ],
      "@hypernexus/core/*": [
        "../core/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ]
}